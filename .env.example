# ─────────────────────────────────────────────────────────────────
# OPTIONAL: Fester KI-Key fuers gesamte System
# ─────────────────────────────────────────────────────────────────
# Wenn diese Variablen gesetzt sind, nutzen ALLE Nutzer automatisch
# diesen Key. Der Setup-Screen wird uebersprungen, Studierende muessen
# nichts eingeben. Ideal fuer den dauerhaften Kursbetrieb.
#
# In Vercel: Settings -> Environment Variables eintragen.
# Wenn NICHT gesetzt, gibt jeder Nutzer seinen eigenen Key ein.

VITE_FIXED_PROVIDER=anthropic        # anthropic | openai | gemini | mistral
VITE_FIXED_API_KEY=sk-ant-...        # der API-Key
VITE_FIXED_MODEL=                    # optional, z.B. claude-haiku-4-5-20251001
